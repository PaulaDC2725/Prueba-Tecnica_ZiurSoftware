@page "/"
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.AspNetCore.Components.QuickGrid
@using System.Text.Json
@using ZiurTest.Blazor.Models
@using ZiurTest.Blazor.Services
@inject IInventarioService InventarioService

<PageTitle>Inventario - Ziur Software</PageTitle>

<div class="container my-4">
    <div class="card shadow border-0 rounded-3 mb-4">
        <div class="card-header bg-primary text-white py-3">
            <div class="d-flex justify-content-between align-items-center">
                <h3 class="card-title mb-0 fs-4 fw-bold">
                    Grilla de Inventario - Ziur Software
                </h3>
                <div class="d-flex gap-2">
                    <button class="btn btn-outline-light btn-sm fw-semibold" @onclick="() => showJsonView = !showJsonView">
                        @(showJsonView ? "Ocultar JSON" : "Ver JSON Renderizado")
                    </button>
                    <button class="btn btn-light btn-sm fw-semibold" @onclick="CargarDatosAsync" disabled="@isLoading">
                        @if (isLoading)
                        {
                            <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                            <span>Actualizando...</span>
                        }
                        else
                        {
                            <span>Recargar</span>
                        }
                    </button>
                </div>
            </div>
        </div>
        <div class="card-body p-4">

            @if (items != null && !items.Any() == false)
            {
                <!-- Tarjetas de métricas -->
                <div class="row g-3 mb-4">
                    <div class="col-md-4">
                        <div class="p-3 bg-light border rounded-3 text-center">
                            <span class="text-muted small d-block">Total de Registros</span>
                            <span class="fs-4 fw-bold text-dark">@items.Count</span>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="p-3 bg-success-subtle border border-success-subtle rounded-3 text-center">
                            <span class="text-success small d-block fw-semibold">Activas</span>
                            <span class="fs-4 fw-bold text-success">@items.Count(i => i.VActiva)</span>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="p-3 bg-danger-subtle border border-danger-subtle rounded-3 text-center">
                            <span class="text-danger small d-block fw-semibold">Inactivas</span>
                            <span class="fs-4 fw-bold text-danger">@items.Count(i => !i.VActiva)</span>
                        </div>
                    </div>
                </div>

                <!-- Filtros -->
                <div class="row g-3 mb-3">
                    <div class="col-md-8">
                        <div class="input-group">
                            <span class="input-group-text bg-white border-end-0">Buscar</span>
                            <input type="text" class="form-control border-start-0 ps-2" 
                                   placeholder="Buscar por código o descripción..." 
                                   @bind="searchTerm" @bind:event="oninput" />
                        </div>
                    </div>
                    <div class="col-md-4">
                        <select class="form-select" @bind="statusFilter">
                            <option value="all">Todos los estados</option>
                            <option value="active">Sólo Activas</option>
                            <option value="inactive">Sólo Inactivas</option>
                        </select>
                    </div>
                </div>
            }

            @if (isLoading)
            {
                <div class="text-center my-5 py-4">
                    <div class="spinner-border text-primary mb-3" style="width: 3rem; height: 3rem;" role="status">
                        <span class="visually-hidden">Cargando datos...</span>
                    </div>
                    <p class="text-muted fw-semibold">Consultando API REST de inventario...</p>
                </div>
            }
            else if (errorMessage != null)
            {
                <div class="alert alert-danger d-flex align-items-center shadow-sm" role="alert">
                    <div>
                        <h5 class="alert-heading mb-1">Error al consultar los datos</h5>
                        <p class="mb-0">@errorMessage</p>
                        <button class="btn btn-outline-danger btn-sm mt-2" @onclick="CargarDatosAsync">
                            Reintentar conexión
                        </button>
                    </div>
                </div>
            }
            else if (items == null || !FilteredItems.Any())
            {
                <div class="alert alert-warning text-center my-4" role="alert">
                    No se encontraron registros que coincidan con la búsqueda o filtro seleccionado.
                </div>
            }
            else
            {
                <div class="table-responsive border rounded-3">
                    <QuickGrid Items="FilteredItems" Pagination="pagination" Class="table table-hover align-middle mb-0">
                        <PropertyColumn Property="@(p => p.Codigo)" Title="Código" Sortable="true" Class="fw-semibold text-center" />
                        <PropertyColumn Property="@(p => p.Descripcion)" Title="Descripción" Sortable="true" />
                        <TemplateColumn Title="Estado (VActiva)" Sortable="true" Class="text-center">
                            @if (context.VActiva)
                            {
                                <span class="badge bg-success px-3 py-2">Activa</span>
                            }
                            else
                            {
                                <span class="badge bg-danger px-3 py-2">Inactiva</span>
                            }
                        </TemplateColumn>
                    </QuickGrid>
                </div>

                <div class="d-flex justify-content-between align-items-center mt-3">
                    <div class="text-muted small">
                        Mostrando <strong>@FilteredItems.Count()</strong> de <strong>@items.Count</strong> registros
                    </div>
                    <div>
                        <Paginator State="pagination" />
                    </div>
                </div>
            }

            @if (showJsonView && FilteredItems != null)
            {
                <div class="mt-4 p-3 bg-dark text-light rounded-3 shadow-sm">
                    <div class="d-flex justify-content-between align-items-center mb-2 border-bottom border-secondary pb-2">
                        <h5 class="mb-0 text-info font-monospace fs-6">JSON Renderizado Actual (@FilteredItems.Count() objetos)</h5>
                        <small class="text-muted">Serialización en tiempo real</small>
                    </div>
                    <pre class="mb-0 font-monospace text-success small" style="max-height: 300px; overflow-y: auto;"><code>@FormattedJson</code></pre>
                </div>
            }
        </div>
    </div>
</div>

@code {
    private List<InventarioItemDto>? items;
    private bool isLoading = true;
    private string? errorMessage;
    private string searchTerm = string.Empty;
    private string statusFilter = "all";
    private bool showJsonView = false;
    private PaginationState pagination = new() { ItemsPerPage = 10 };

    private string FormattedJson
    {
        get
        {
            if (FilteredItems == null) return "[]";
            var options = new JsonSerializerOptions { WriteIndented = true };
            return JsonSerializer.Serialize(FilteredItems.ToList(), options);
        }
    }

    private IQueryable<InventarioItemDto> FilteredItems
    {
        get
        {
            if (items == null) return Enumerable.Empty<InventarioItemDto>().AsQueryable();

            var query = items.AsQueryable();

            if (!string.IsNullOrWhiteSpace(searchTerm))
            {
                query = query.Where(i =>
                    (i.Descripcion != null && i.Descripcion.Contains(searchTerm, StringComparison.OrdinalIgnoreCase)) ||
                    i.Codigo.ToString().Contains(searchTerm));
            }

            if (statusFilter == "active")
            {
                query = query.Where(i => i.VActiva);
            }
            else if (statusFilter == "inactive")
            {
                query = query.Where(i => !i.VActiva);
            }

            return query;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await CargarDatosAsync();
    }

    private async Task CargarDatosAsync()
    {
        try
        {
            isLoading = true;
            errorMessage = null;
            items = await InventarioService.GetItemsAsync();
        }
        catch (Exception ex)
        {
            errorMessage = $"Error de red o comunicación con la API: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }
}